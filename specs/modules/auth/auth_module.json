{
  "module": "auth",
  "entity": "User",
  "table": "users",
  "description": "Authentication and account access for platform users",
  "scope": "control",
  "permissions": [
    "auth.me"
  ],
  "fields": [
    {
      "name": "id",
      "type": "uuid",
      "primary": true,
      "required": true
    },
    {
      "name": "email",
      "type": "string",
      "required": true,
      "unique": true
    },
    {
      "name": "emailNormalized",
      "type": "string",
      "required": true,
      "unique": true
    },
    {
      "name": "passwordHash",
      "type": "string",
      "required": false
    },
    {
      "name": "passwordSetAt",
      "type": "datetime",
      "required": false
    },
    {
      "name": "status",
      "type": "enum",
      "required": true,
      "values": [
        "invited",
        "active",
        "blocked",
        "pending_email_verification"
      ]
    },
    {
      "name": "firstName",
      "type": "string",
      "required": false
    },
    {
      "name": "lastName",
      "type": "string",
      "required": false
    },
    {
      "name": "fullName",
      "type": "string",
      "required": false
    },
    {
      "name": "phone",
      "type": "string",
      "required": false
    },
    {
      "name": "locale",
      "type": "string",
      "required": false,
      "default": "es-CL"
    },
    {
      "name": "lastLoginAt",
      "type": "datetime",
      "required": false
    }
  ],
  "actions": [
    {
      "name": "login",
      "method": "POST",
      "path": "/api/v1/auth/login",
      "authRequired": false
    },
    {
      "name": "logout",
      "method": "POST",
      "path": "/api/v1/auth/logout",
      "authRequired": true
    },
    {
      "name": "me",
      "method": "GET",
      "path": "/api/v1/auth/me",
      "authRequired": true
    },
    {
      "name": "verifyEmail",
      "method": "POST",
      "path": "/api/v1/auth/verify-email",
      "authRequired": false
    },
    {
      "name": "resendVerifyEmail",
      "method": "POST",
      "path": "/api/v1/auth/resend-verify-email",
      "authRequired": false
    },
    {
      "name": "setPassword",
      "method": "POST",
      "path": "/api/v1/auth/set-password",
      "authRequired": false
    },
    {
      "name": "forgotPassword",
      "method": "POST",
      "path": "/api/v1/auth/forgot-password",
      "authRequired": false
    },
    {
      "name": "resetPassword",
      "method": "POST",
      "path": "/api/v1/auth/reset-password",
      "authRequired": false
    },
    {
      "name": "changePassword",
      "method": "POST",
      "path": "/api/v1/auth/change-password",
      "authRequired": true
    }
  ],
  "rules": [
    "email must be normalized before lookup",
    "blocked users cannot login",
    "users without password set cannot login with password flow",
    "passwords are stored only as secure hash",
    "verify email token must expire and be one-time use",
    "password setup token must expire and be one-time use",
    "password reset token must expire and be one-time use",
    "login updates last_login_at",
    "user must belong to at least one company to access tenant data"
  ],
  "tables": [
    "users",
    "company_users",
    "email_verifications",
    "password_setup_tokens",
    "password_reset_tokens"
  ],
  "ui": {
    "pages": [
      "login",
      "forgot-password",
      "reset-password",
      "verify-email",
      "set-password",
      "profile",
      "change-password"
    ]
  }
}