{
  "module": "auth",
  "entity": "User",
  "table": "users",
  "description": "Authentication and account access for platform users",
  "scope": "control",
  "database": {
    "owner": "auth",
    "tables": [
      {
        "name": "users",
        "owner": "auth",
        "scope": "control",
        "columns": [
          { "name": "id", "type": "uuid", "nullable": false, "primary": true },
          { "name": "email", "type": "varchar(255)", "nullable": false },
          { "name": "email_normalized", "type": "varchar(255)", "nullable": false },
          { "name": "password_hash", "type": "varchar(255)", "nullable": true },
          { "name": "password_set_at", "type": "timestamptz", "nullable": true },
          { "name": "status", "type": "varchar(50)", "nullable": false },
          { "name": "first_name", "type": "varchar(120)", "nullable": true },
          { "name": "last_name", "type": "varchar(120)", "nullable": true },
          { "name": "full_name", "type": "varchar(240)", "nullable": true },
          { "name": "phone", "type": "varchar(40)", "nullable": true },
          { "name": "locale", "type": "varchar(20)", "nullable": false, "default": "es-CL" },
          { "name": "last_login_at", "type": "timestamptz", "nullable": true },
          { "name": "created_at", "type": "timestamptz", "nullable": false },
          { "name": "updated_at", "type": "timestamptz", "nullable": false }
        ],
        "indexes": [
          { "name": "ux_users_email", "columns": ["email"], "unique": true },
          { "name": "ux_users_email_normalized", "columns": ["email_normalized"], "unique": true }
        ],
        "foreignKeys": []
      },
      {
        "name": "company_users",
        "owner": "auth",
        "scope": "control",
        "columns": [
          { "name": "company_id", "type": "uuid", "nullable": false },
          { "name": "user_id", "type": "uuid", "nullable": false },
          { "name": "status", "type": "varchar(50)", "nullable": false },
          { "name": "created_at", "type": "timestamptz", "nullable": false }
        ],
        "indexes": [
          { "name": "ux_company_users_company_user", "columns": ["company_id", "user_id"], "unique": true },
          { "name": "idx_company_users_user_id", "columns": ["user_id"], "unique": false }
        ],
        "foreignKeys": [
          {
            "name": "fk_company_users_user_id",
            "column": "user_id",
            "references": { "table": "users", "column": "id" },
            "onDelete": "cascade"
          }
        ]
      },
      {
        "name": "email_verifications",
        "owner": "auth",
        "scope": "control",
        "columns": [
          { "name": "id", "type": "uuid", "nullable": false, "primary": true },
          { "name": "user_id", "type": "uuid", "nullable": false },
          { "name": "token_hash", "type": "varchar(255)", "nullable": false },
          { "name": "expires_at", "type": "timestamptz", "nullable": false },
          { "name": "used_at", "type": "timestamptz", "nullable": true },
          { "name": "created_at", "type": "timestamptz", "nullable": false }
        ],
        "indexes": [
          { "name": "ux_email_verifications_token_hash", "columns": ["token_hash"], "unique": true }
        ],
        "foreignKeys": [
          {
            "name": "fk_email_verifications_user_id",
            "column": "user_id",
            "references": { "table": "users", "column": "id" },
            "onDelete": "cascade"
          }
        ]
      },
      {
        "name": "password_setup_tokens",
        "owner": "auth",
        "scope": "control",
        "columns": [
          { "name": "id", "type": "uuid", "nullable": false, "primary": true },
          { "name": "user_id", "type": "uuid", "nullable": false },
          { "name": "token_hash", "type": "varchar(255)", "nullable": false },
          { "name": "expires_at", "type": "timestamptz", "nullable": false },
          { "name": "used_at", "type": "timestamptz", "nullable": true },
          { "name": "created_at", "type": "timestamptz", "nullable": false }
        ],
        "indexes": [
          { "name": "ux_password_setup_tokens_token_hash", "columns": ["token_hash"], "unique": true }
        ],
        "foreignKeys": [
          {
            "name": "fk_password_setup_tokens_user_id",
            "column": "user_id",
            "references": { "table": "users", "column": "id" },
            "onDelete": "cascade"
          }
        ]
      },
      {
        "name": "password_reset_tokens",
        "owner": "auth",
        "scope": "control",
        "columns": [
          { "name": "id", "type": "uuid", "nullable": false, "primary": true },
          { "name": "user_id", "type": "uuid", "nullable": false },
          { "name": "token_hash", "type": "varchar(255)", "nullable": false },
          { "name": "expires_at", "type": "timestamptz", "nullable": false },
          { "name": "used_at", "type": "timestamptz", "nullable": true },
          { "name": "created_at", "type": "timestamptz", "nullable": false }
        ],
        "indexes": [
          { "name": "ux_password_reset_tokens_token_hash", "columns": ["token_hash"], "unique": true }
        ],
        "foreignKeys": [
          {
            "name": "fk_password_reset_tokens_user_id",
            "column": "user_id",
            "references": { "table": "users", "column": "id" },
            "onDelete": "cascade"
          }
        ]
      }
    ],
    "migrations": {
      "enabled": true,
      "runner": "embedded_sql",
      "autoRunOnStartup": true,
      "controlTable": "schema_migrations",
      "namingPattern": "000001_init_auth_schema.sql",
      "seedsSeparated": true
    }
  },
  "migrations": {
    "enabled": true,
    "strategy": "embedded_sql",
    "autoRunOnStartup": true
  },
  "docker": {
    "enabled": true,
    "files": ["Dockerfile", "docker-compose.yml", ".dockerignore"],
    "services": ["api", "postgres"],
    "appPort": 8080,
    "requiredEnv": [
      "APP_ENV",
      "APP_PORT",
      "DB_HOST",
      "DB_PORT",
      "DB_USER",
      "DB_PASSWORD",
      "DB_NAME",
      "DB_SSLMODE",
      "DB_AUTO_MIGRATE",
      "JWT_SECRET",
      "JWT_EXPIRATION"
    ],
    "healthcheck": {
      "type": "http",
      "path": "/health"
    }
  },
  "postman": {
    "enabled": true,
    "collectionStrategy": "single_project_collection",
    "collectionGroup": "auth",
    "environment": "local",
    "files": [
      "postman/base.postman_collection.json",
      "postman/local.postman_environment.json"
    ],
    "variables": [
      "baseUrl",
      "accessToken",
      "refreshToken",
      "userId",
      "companyId",
      "resourceId"
    ],
    "captureAccessTokenFrom": "login",
    "examplesPerAction": true
  },
  "makeTargets": [
    "fmt",
    "tidy",
    "build",
    "test",
    "run",
    "verify",
    "docker-up",
    "docker-down"
  ],
  "examples": {
    "requests": [
      {
        "action": "login",
        "name": "default",
        "body": {
          "email": "admin@example.com",
          "password": "ChangeMe123!"
        }
      },
      {
        "action": "forgotPassword",
        "name": "default",
        "body": {
          "email": "admin@example.com"
        }
      }
    ],
    "responses": [
      {
        "action": "login",
        "name": "success",
        "status": 200,
        "body": {
          "accessToken": "<jwt>",
          "refreshToken": "<refresh-token>",
          "userId": "<user-id>"
        }
      },
      {
        "action": "me",
        "name": "success",
        "status": 200,
        "body": {
          "id": "<user-id>",
          "email": "admin@example.com",
          "status": "active"
        }
      },
      {
        "action": "me",
        "name": "unauthorized",
        "status": 401,
        "body": {
          "success": false,
          "message": "Unauthorized",
          "error": {
            "code": "UNAUTHORIZED"
          }
        }
      }
    ]
  },
  "permissions": ["auth.me"],
  "authStrategy": {
    "type": "jwt_refresh",
    "accessTokenTTLMinutes": 60,
    "refreshTokenTTLDays": 30,
    "logoutRevokesRefreshToken": true,
    "allowConcurrentSessions": true
  },
  "tokenPolicies": {
    "emailVerificationHours": 24,
    "passwordSetupHours": 72,
    "passwordResetHours": 1
  },
  "passwordPolicy": {
    "minLength": 8,
    "requireUppercase": true,
    "requireLowercase": true,
    "requireNumber": true,
    "requireSymbol": true
  },
  "statusPolicies": {
    "invited": {
      "canLoginWithPassword": false
    },
    "active": {
      "canLoginWithPassword": true
    },
    "blocked": {
      "canLoginWithPassword": false
    },
    "pending_email_verification": {
      "canLoginWithPassword": false
    }
  },
  "membershipPolicy": {
    "loginRequiresCompanyMembership": false,
    "tenantAccessRequiresCompanyMembership": true,
    "allowedCompanyUserStatuses": ["active"]
  },
  "authTransport": {
    "scheme": "Bearer",
    "header": "Authorization"
  },
  "middlewareContract": {
    "requiredForActions": ["me", "logout", "changePassword"],
    "contextValues": ["userID", "email", "sessionID"],
    "tokenValidatedIn": "http_middleware",
    "handlersReadFrom": "fiber_locals",
    "unauthorizedErrorCode": "UNAUTHORIZED",
    "unauthorizedResponse": {
      "httpStatus": 401,
      "body": {
        "success": false,
        "message": "Unauthorized",
        "error": {
          "code": "UNAUTHORIZED"
        }
      }
    }
  },
  "jwtClaims": {
    "subject": "sub",
    "issuer": "iss",
    "email": "eml",
    "sessionId": "sid",
    "issuedAt": "iat",
    "expiresAt": "exp"
  },
  "securityControls": {
    "rateLimit": {
      "login": {
        "byIP": "10/5m",
        "byNormalizedEmailFailed": "5/15m"
      },
      "forgotPassword": {
        "byIP": "5/15m",
        "byNormalizedEmail": "3/30m"
      }
    },
    "storeRawTokens": false,
    "auditEnabled": true
  },
  "mailFlows": {
    "verifyEmailTemplate": "auth.verify-email",
    "resetPasswordTemplate": "auth.reset-password",
    "setPasswordTemplate": "auth.set-password"
  },
  "fields": [
    {
      "name": "id",
      "type": "uuid",
      "primary": true,
      "required": true
    },
    {
      "name": "email",
      "type": "string",
      "required": true,
      "unique": true
    },
    {
      "name": "emailNormalized",
      "type": "string",
      "required": true,
      "unique": true
    },
    {
      "name": "passwordHash",
      "type": "string",
      "required": false
    },
    {
      "name": "passwordSetAt",
      "type": "datetime",
      "required": false
    },
    {
      "name": "status",
      "type": "enum",
      "required": true,
      "values": ["invited", "active", "blocked", "pending_email_verification"]
    },
    {
      "name": "firstName",
      "type": "string",
      "required": false
    },
    {
      "name": "lastName",
      "type": "string",
      "required": false
    },
    {
      "name": "fullName",
      "type": "string",
      "required": false
    },
    {
      "name": "phone",
      "type": "string",
      "required": false
    },
    {
      "name": "locale",
      "type": "string",
      "required": false,
      "default": "es-CL"
    },
    {
      "name": "lastLoginAt",
      "type": "datetime",
      "required": false
    }
  ],
  "actions": [
    {
      "name": "login",
      "method": "POST",
      "path": "/api/v1/auth/login",
      "authRequired": false
    },
    {
      "name": "logout",
      "method": "POST",
      "path": "/api/v1/auth/logout",
      "authRequired": true
    },
    {
      "name": "me",
      "method": "GET",
      "path": "/api/v1/auth/me",
      "authRequired": true
    },
    {
      "name": "verifyEmail",
      "method": "POST",
      "path": "/api/v1/auth/verify-email",
      "authRequired": false
    },
    {
      "name": "resendVerifyEmail",
      "method": "POST",
      "path": "/api/v1/auth/resend-verify-email",
      "authRequired": false
    },
    {
      "name": "setPassword",
      "method": "POST",
      "path": "/api/v1/auth/set-password",
      "authRequired": false
    },
    {
      "name": "forgotPassword",
      "method": "POST",
      "path": "/api/v1/auth/forgot-password",
      "authRequired": false
    },
    {
      "name": "resetPassword",
      "method": "POST",
      "path": "/api/v1/auth/reset-password",
      "authRequired": false
    },
    {
      "name": "changePassword",
      "method": "POST",
      "path": "/api/v1/auth/change-password",
      "authRequired": true
    }
  ],
  "rules": [
    "email must be normalized before lookup",
    "blocked users cannot login",
    "invited users cannot login with password until password is set",
    "pending email verification users cannot login with password until email is verified",
    "passwords are stored only as secure hash",
    "verify email token must expire and be one-time use",
    "password setup token must expire and be one-time use",
    "password reset token must expire and be one-time use",
    "login updates last_login_at",
    "login may succeed without company membership, but tenant access requires at least one active company membership",
    "logout revokes current refresh token/session"
  ],
  "tables": [
    "users",
    "company_users",
    "email_verifications",
    "password_setup_tokens",
    "password_reset_tokens"
  ],
  "errors": [
    { "code": "INVALID_CREDENTIALS", "httpStatus": 401 },
    { "code": "USER_BLOCKED", "httpStatus": 403 },
    { "code": "PASSWORD_NOT_SET", "httpStatus": 403 },
    { "code": "UNAUTHORIZED", "httpStatus": 401 },
    { "code": "INVALID_CURRENT_PASSWORD", "httpStatus": 422 },
    { "code": "TOKEN_EXPIRED", "httpStatus": 422 },
    { "code": "TOKEN_ALREADY_USED", "httpStatus": 422 },
    { "code": "VALIDATION_ERROR", "httpStatus": 400 },
    { "code": "RATE_LIMITED", "httpStatus": 429 }
  ],
  "ui": {
    "pages": [
      "login",
      "forgot-password",
      "reset-password",
      "verify-email",
      "set-password",
      "profile",
      "change-password"
    ]
  }
}
