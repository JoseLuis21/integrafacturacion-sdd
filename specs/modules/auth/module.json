{
  "module": "auth",
  "entity": "User",
  "table": "users",
  "description": "Authentication and account access for platform users",
  "scope": "control",
  "permissions": ["auth.me"],
  "authStrategy": {
    "type": "jwt_refresh",
    "accessTokenTTLMinutes": 60,
    "refreshTokenTTLDays": 30,
    "logoutRevokesRefreshToken": true,
    "allowConcurrentSessions": true
  },
  "tokenPolicies": {
    "emailVerificationHours": 24,
    "passwordSetupHours": 72,
    "passwordResetHours": 1
  },
  "passwordPolicy": {
    "minLength": 8,
    "requireUppercase": true,
    "requireLowercase": true,
    "requireNumber": true,
    "requireSymbol": true
  },
  "statusPolicies": {
    "invited": {
      "canLoginWithPassword": false
    },
    "active": {
      "canLoginWithPassword": true
    },
    "blocked": {
      "canLoginWithPassword": false
    },
    "pending_email_verification": {
      "canLoginWithPassword": false
    }
  },
  "membershipPolicy": {
    "loginRequiresCompanyMembership": false,
    "tenantAccessRequiresCompanyMembership": true,
    "allowedCompanyUserStatuses": ["active"]
  },
  "middlewareContract": {
    "locals": ["userID", "sessionID", "email"],
    "jwtClaims": ["sub", "sid", "eml", "iss", "iat", "exp"]
  },
  "securityControls": {
    "rateLimit": {
      "login": {
        "byIP": "10/5m",
        "byNormalizedEmailFailed": "5/15m"
      },
      "forgotPassword": {
        "byIP": "5/15m",
        "byNormalizedEmail": "3/30m"
      }
    },
    "storeRawTokens": false,
    "auditEnabled": true
  },
  "mailFlows": {
    "verifyEmailTemplate": "auth.verify-email",
    "resetPasswordTemplate": "auth.reset-password",
    "setPasswordTemplate": "auth.set-password"
  },
  "fields": [
    {
      "name": "id",
      "type": "uuid",
      "primary": true,
      "required": true
    },
    {
      "name": "email",
      "type": "string",
      "required": true,
      "unique": true
    },
    {
      "name": "emailNormalized",
      "type": "string",
      "required": true,
      "unique": true
    },
    {
      "name": "passwordHash",
      "type": "string",
      "required": false
    },
    {
      "name": "passwordSetAt",
      "type": "datetime",
      "required": false
    },
    {
      "name": "status",
      "type": "enum",
      "required": true,
      "values": ["invited", "active", "blocked", "pending_email_verification"]
    },
    {
      "name": "firstName",
      "type": "string",
      "required": false
    },
    {
      "name": "lastName",
      "type": "string",
      "required": false
    },
    {
      "name": "fullName",
      "type": "string",
      "required": false
    },
    {
      "name": "phone",
      "type": "string",
      "required": false
    },
    {
      "name": "locale",
      "type": "string",
      "required": false,
      "default": "es-CL"
    },
    {
      "name": "lastLoginAt",
      "type": "datetime",
      "required": false
    }
  ],
  "actions": [
    {
      "name": "login",
      "method": "POST",
      "path": "/api/v1/auth/login",
      "authRequired": false
    },
    {
      "name": "logout",
      "method": "POST",
      "path": "/api/v1/auth/logout",
      "authRequired": true
    },
    {
      "name": "me",
      "method": "GET",
      "path": "/api/v1/auth/me",
      "authRequired": true
    },
    {
      "name": "verifyEmail",
      "method": "POST",
      "path": "/api/v1/auth/verify-email",
      "authRequired": false
    },
    {
      "name": "resendVerifyEmail",
      "method": "POST",
      "path": "/api/v1/auth/resend-verify-email",
      "authRequired": false
    },
    {
      "name": "setPassword",
      "method": "POST",
      "path": "/api/v1/auth/set-password",
      "authRequired": false
    },
    {
      "name": "forgotPassword",
      "method": "POST",
      "path": "/api/v1/auth/forgot-password",
      "authRequired": false
    },
    {
      "name": "resetPassword",
      "method": "POST",
      "path": "/api/v1/auth/reset-password",
      "authRequired": false
    },
    {
      "name": "changePassword",
      "method": "POST",
      "path": "/api/v1/auth/change-password",
      "authRequired": true
    }
  ],
  "rules": [
    "email must be normalized before lookup",
    "blocked users cannot login",
    "invited users cannot login with password until password is set",
    "pending email verification users cannot login with password until email is verified",
    "passwords are stored only as secure hash",
    "verify email token must expire and be one-time use",
    "password setup token must expire and be one-time use",
    "password reset token must expire and be one-time use",
    "login updates last_login_at",
    "login may succeed without company membership, but tenant access requires at least one active company membership",
    "logout revokes current refresh token/session"
  ],
  "tables": [
    "users",
    "company_users",
    "email_verifications",
    "password_setup_tokens",
    "password_reset_tokens"
  ],
  "errors": [
    { "code": "INVALID_CREDENTIALS", "httpStatus": 401 },
    { "code": "USER_BLOCKED", "httpStatus": 403 },
    { "code": "PASSWORD_NOT_SET", "httpStatus": 403 },
    { "code": "UNAUTHORIZED", "httpStatus": 401 },
    { "code": "INVALID_CURRENT_PASSWORD", "httpStatus": 422 },
    { "code": "TOKEN_EXPIRED", "httpStatus": 422 },
    { "code": "TOKEN_ALREADY_USED", "httpStatus": 422 },
    { "code": "VALIDATION_ERROR", "httpStatus": 400 },
    { "code": "RATE_LIMITED", "httpStatus": 429 }
  ],
  "ui": {
    "pages": [
      "login",
      "forgot-password",
      "reset-password",
      "verify-email",
      "set-password",
      "profile",
      "change-password"
    ]
  }
}
