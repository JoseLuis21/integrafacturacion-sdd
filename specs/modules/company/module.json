{
  "module": "company",
  "entity": "Company",
  "table": "companies",
  "description": "Company onboarding, Chilean tax profile management, and tenant schema provisioning",
  "scope": "control",
  "database": {
    "owner": "company",
    "tables": [
      {
        "name": "companies",
        "owner": "company",
        "scope": "control",
        "columns": [
          { "name": "id", "type": "uuid", "nullable": false, "primary": true },
          { "name": "tenant_code", "type": "varchar(80)", "nullable": false },
          { "name": "tenant_schema", "type": "varchar(120)", "nullable": false },
          { "name": "rut", "type": "varchar(20)", "nullable": false },
          { "name": "rut_normalized", "type": "varchar(12)", "nullable": false },
          { "name": "legal_name", "type": "varchar(255)", "nullable": false },
          { "name": "trade_name", "type": "varchar(255)", "nullable": true },
          { "name": "status", "type": "varchar(50)", "nullable": false, "default": "onboarding" },
          { "name": "onboarding_status", "type": "varchar(50)", "nullable": false, "default": "provisioning" },
          { "name": "primary_giro", "type": "varchar(255)", "nullable": false },
          { "name": "sii_environment", "type": "varchar(30)", "nullable": false, "default": "certification" },
          { "name": "sii_resolution_number", "type": "varchar(30)", "nullable": true },
          { "name": "sii_resolution_date", "type": "date", "nullable": true },
          { "name": "dte_email", "type": "varchar(255)", "nullable": true },
          { "name": "contact_email", "type": "varchar(255)", "nullable": false },
          { "name": "billing_email", "type": "varchar(255)", "nullable": true },
          { "name": "phone", "type": "varchar(40)", "nullable": true },
          { "name": "website", "type": "varchar(255)", "nullable": true },
          { "name": "logo_url", "type": "varchar(500)", "nullable": true },
          { "name": "default_currency", "type": "varchar(10)", "nullable": false, "default": "CLP" },
          { "name": "locale", "type": "varchar(20)", "nullable": false, "default": "es-CL" },
          { "name": "timezone", "type": "varchar(60)", "nullable": false, "default": "America/Santiago" },
          { "name": "created_by_user_id", "type": "uuid", "nullable": false },
          { "name": "activated_at", "type": "timestamptz", "nullable": true },
          { "name": "suspended_at", "type": "timestamptz", "nullable": true },
          { "name": "created_at", "type": "timestamptz", "nullable": false },
          { "name": "updated_at", "type": "timestamptz", "nullable": false }
        ],
        "indexes": [
          { "name": "ux_companies_rut_normalized", "columns": ["rut_normalized"], "unique": true },
          { "name": "ux_companies_tenant_code", "columns": ["tenant_code"], "unique": true },
          { "name": "ux_companies_tenant_schema", "columns": ["tenant_schema"], "unique": true },
          { "name": "idx_companies_status", "columns": ["status"], "unique": false },
          { "name": "idx_companies_created_by_user_id", "columns": ["created_by_user_id"], "unique": false }
        ],
        "foreignKeys": [
          {
            "name": "fk_companies_created_by_user_id",
            "column": "created_by_user_id",
            "references": { "table": "users", "column": "id" },
            "onDelete": "restrict"
          }
        ]
      },
      {
        "name": "company_branches",
        "owner": "company",
        "scope": "control",
        "columns": [
          { "name": "id", "type": "uuid", "nullable": false, "primary": true },
          { "name": "company_id", "type": "uuid", "nullable": false },
          { "name": "branch_name", "type": "varchar(150)", "nullable": false },
          { "name": "branch_type", "type": "varchar(30)", "nullable": false, "default": "branch" },
          { "name": "sii_branch_code", "type": "varchar(20)", "nullable": true },
          { "name": "is_default", "type": "boolean", "nullable": false, "default": false },
          { "name": "status", "type": "varchar(30)", "nullable": false, "default": "active" },
          { "name": "email", "type": "varchar(255)", "nullable": true },
          { "name": "phone", "type": "varchar(40)", "nullable": true },
          { "name": "street", "type": "varchar(150)", "nullable": false },
          { "name": "street_number", "type": "varchar(20)", "nullable": false },
          { "name": "address_line2", "type": "varchar(150)", "nullable": true },
          { "name": "commune_code", "type": "varchar(20)", "nullable": false },
          { "name": "commune_name", "type": "varchar(120)", "nullable": false },
          { "name": "city", "type": "varchar(120)", "nullable": false },
          { "name": "region_code", "type": "varchar(20)", "nullable": false },
          { "name": "region_name", "type": "varchar(120)", "nullable": false },
          { "name": "country_code", "type": "varchar(2)", "nullable": false, "default": "CL" },
          { "name": "postal_code", "type": "varchar(20)", "nullable": true },
          { "name": "created_at", "type": "timestamptz", "nullable": false },
          { "name": "updated_at", "type": "timestamptz", "nullable": false }
        ],
        "indexes": [
          { "name": "idx_company_branches_company_id", "columns": ["company_id"], "unique": false },
          { "name": "ux_company_branches_company_branch_name", "columns": ["company_id", "branch_name"], "unique": true },
          { "name": "ux_company_branches_company_sii_branch_code", "columns": ["company_id", "sii_branch_code"], "unique": true }
        ],
        "foreignKeys": [
          {
            "name": "fk_company_branches_company_id",
            "column": "company_id",
            "references": { "table": "companies", "column": "id" },
            "onDelete": "cascade"
          }
        ]
      },
      {
        "name": "company_economic_activities",
        "owner": "company",
        "scope": "control",
        "columns": [
          { "name": "id", "type": "uuid", "nullable": false, "primary": true },
          { "name": "company_id", "type": "uuid", "nullable": false },
          { "name": "sii_activity_code", "type": "varchar(10)", "nullable": false },
          { "name": "activity_name", "type": "varchar(255)", "nullable": false },
          { "name": "is_primary", "type": "boolean", "nullable": false, "default": false },
          { "name": "created_at", "type": "timestamptz", "nullable": false }
        ],
        "indexes": [
          { "name": "ux_company_economic_activities_company_code", "columns": ["company_id", "sii_activity_code"], "unique": true },
          { "name": "idx_company_economic_activities_company_primary", "columns": ["company_id", "is_primary"], "unique": false }
        ],
        "foreignKeys": [
          {
            "name": "fk_company_economic_activities_company_id",
            "column": "company_id",
            "references": { "table": "companies", "column": "id" },
            "onDelete": "cascade"
          }
        ]
      },
      {
        "name": "company_tenant_provisioning",
        "owner": "company",
        "scope": "control",
        "columns": [
          { "name": "company_id", "type": "uuid", "nullable": false, "primary": true },
          { "name": "tenant_schema", "type": "varchar(120)", "nullable": false },
          { "name": "provisioning_status", "type": "varchar(50)", "nullable": false, "default": "pending" },
          { "name": "bootstrap_version", "type": "varchar(50)", "nullable": false, "default": "v1" },
          { "name": "requested_by_user_id", "type": "uuid", "nullable": true },
          { "name": "started_at", "type": "timestamptz", "nullable": true },
          { "name": "finished_at", "type": "timestamptz", "nullable": true },
          { "name": "last_error_code", "type": "varchar(100)", "nullable": true },
          { "name": "last_error_message", "type": "text", "nullable": true },
          { "name": "created_at", "type": "timestamptz", "nullable": false },
          { "name": "updated_at", "type": "timestamptz", "nullable": false }
        ],
        "indexes": [
          { "name": "ux_company_tenant_provisioning_tenant_schema", "columns": ["tenant_schema"], "unique": true },
          { "name": "idx_company_tenant_provisioning_status", "columns": ["provisioning_status"], "unique": false }
        ],
        "foreignKeys": [
          {
            "name": "fk_company_tenant_provisioning_company_id",
            "column": "company_id",
            "references": { "table": "companies", "column": "id" },
            "onDelete": "cascade"
          },
          {
            "name": "fk_company_tenant_provisioning_requested_by_user_id",
            "column": "requested_by_user_id",
            "references": { "table": "users", "column": "id" },
            "onDelete": "set null"
          }
        ]
      }
    ],
    "migrations": {
      "enabled": true,
      "runner": "embedded_sql",
      "autoRunOnStartup": true,
      "controlTable": "schema_migrations",
      "namingPattern": "000001_init_company_schema.sql",
      "seedsSeparated": true
    }
  },
  "migrations": {
    "enabled": true,
    "strategy": "embedded_sql",
    "autoRunOnStartup": true
  },
  "docker": {
    "enabled": true,
    "files": ["Dockerfile", "docker-compose.yml", ".dockerignore"],
    "services": ["api", "postgres"],
    "appPort": 8080,
    "requiredEnv": [
      "APP_ENV",
      "APP_PORT",
      "DB_HOST",
      "DB_PORT",
      "DB_USER",
      "DB_PASSWORD",
      "DB_NAME",
      "DB_SSLMODE",
      "DB_AUTO_MIGRATE"
    ],
    "healthcheck": {
      "type": "http",
      "path": "/health"
    }
  },
  "postman": {
    "enabled": true,
    "collectionStrategy": "single_project_collection",
    "collectionGroup": "company",
    "environment": "local",
    "files": [
      "postman/base.postman_collection.json",
      "postman/local.postman_environment.json"
    ],
    "variables": [
      "baseUrl",
      "accessToken",
      "refreshToken",
      "userId",
      "companyId",
      "resourceId"
    ],
    "captureAccessTokenFrom": "login",
    "examplesPerAction": true
  },
  "makeTargets": [
    "fmt",
    "tidy",
    "build",
    "test",
    "run",
    "verify",
    "docker-up",
    "docker-down"
  ],
  "authTransport": {
    "scheme": "Bearer",
    "header": "Authorization"
  },
  "middlewareContract": {
    "requiredForActions": [
      "createCompany",
      "listCompanies",
      "getMyCompanies",
      "getCompanyById",
      "updateCompany",
      "activateCompany",
      "suspendCompany",
      "getTenantProvisioning",
      "retryTenantProvisioning",
      "listBranches",
      "createBranch",
      "updateBranch",
      "setDefaultBranch"
    ],
    "contextValues": ["userID", "email", "permissions"],
    "tokenValidatedIn": "http_middleware",
    "handlersReadFrom": "fiber_locals",
    "unauthorizedErrorCode": "UNAUTHORIZED",
    "unauthorizedResponse": {
      "httpStatus": 401,
      "body": {
        "success": false,
        "message": "Unauthorized",
        "error": {
          "code": "UNAUTHORIZED"
        }
      }
    }
  },
  "tenantProvisioning": {
    "strategy": "control_database_plus_tenant_schema",
    "schemaNamePattern": "tenant_<tenant_code>",
    "searchPathTemplate": "SET search_path TO <tenant_schema>, public",
    "createSchemaOnCompanyCreation": true,
    "runBaseTenantMigrations": true,
    "seedCompanyProfileInTenantSchema": true,
    "ownerMembershipCreatedOnCompanyCreation": true,
    "statuses": ["pending", "provisioning", "ready", "failed"]
  },
  "chileProfile": {
    "defaultCountryCode": "CL",
    "defaultCurrency": "CLP",
    "defaultLocale": "es-CL",
    "defaultTimezone": "America/Santiago",
    "validateRut": true,
    "siiEnvironments": ["certification", "production"],
    "requiredAddressFields": [
      "street",
      "streetNumber",
      "communeCode",
      "communeName",
      "city",
      "regionCode",
      "regionName",
      "countryCode"
    ],
    "requiredForProductionDTE": [
      "primaryGiro",
      "dteEmail",
      "siiResolutionNumber",
      "siiResolutionDate",
      "mainBranch",
      "economicActivities"
    ]
  },
  "statusPolicies": {
    "company": {
      "onboarding": {
        "tenantAccessAllowed": false
      },
      "active": {
        "tenantAccessAllowed": true
      },
      "suspended": {
        "tenantAccessAllowed": false
      },
      "archived": {
        "tenantAccessAllowed": false
      }
    },
    "provisioning": {
      "pending": {
        "activatable": false
      },
      "provisioning": {
        "activatable": false
      },
      "ready": {
        "activatable": true
      },
      "failed": {
        "activatable": false
      }
    },
    "branch": {
      "active": {
        "usableForDTE": true
      },
      "inactive": {
        "usableForDTE": false
      }
    }
  },
