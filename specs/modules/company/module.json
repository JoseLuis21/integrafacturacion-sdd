            "finishedAt": "2026-03-12T10:00:06Z"
          }
        }
      },
      {
        "action": "retryTenantProvisioning",
        "name": "accepted",
        "status": 202,
        "body": {
          "success": true,
          "data": {
            "companyId": "<company-id>",
            "provisioningStatus": "provisioning"
          }
        }
      }
    ]
  },
  "permissions": [
    "company.read",
    "company.create",
    "company.update",
    "company.activate",
    "company.suspend",
    "company.branch.read",
    "company.branch.create",
    "company.branch.update",
    "company.tenant.read",
    "company.tenant.retry"
  ],
  "fields": [
    {
      "name": "id",
      "type": "uuid",
      "primary": true,
      "required": true
    },
    {
      "name": "tenantCode",
      "type": "string",
      "required": true,
      "unique": true
    },
    {
      "name": "tenantSchema",
      "type": "string",
      "required": true,
      "unique": true
    },
    {
      "name": "rut",
      "type": "string",
      "required": true,
      "unique": true,
      "format": "chilean_rut"
    },
    {
      "name": "rutNormalized",
      "type": "string",
      "required": true,
      "unique": true
    },
    {
      "name": "legalName",
      "type": "string",
      "required": true
    },
    {
      "name": "tradeName",
      "type": "string",
      "required": false
    },
    {
      "name": "status",
      "type": "enum",
      "required": true,
      "values": ["onboarding", "active", "suspended", "archived"]
    },
    {
      "name": "onboardingStatus",
      "type": "enum",
      "required": true,
      "values": ["pending", "provisioning", "ready", "failed"]
    },
    {
      "name": "primaryGiro",
      "type": "string",
      "required": true
    },
    {
      "name": "siiEnvironment",
      "type": "enum",
      "required": true,
      "values": ["certification", "production"]
    },
    {
      "name": "siiResolutionNumber",
      "type": "string",
      "required": false
    },
    {
      "name": "siiResolutionDate",
      "type": "date",
      "required": false
    },
    {
      "name": "dteEmail",
      "type": "string",
      "required": false
    },
    {
      "name": "contactEmail",
      "type": "string",
      "required": true
    },
    {
      "name": "billingEmail",
      "type": "string",
      "required": false
    },
    {
      "name": "phone",
      "type": "string",
      "required": false
    },
    {
      "name": "website",
      "type": "string",
      "required": false
    },
    {
      "name": "defaultCurrency",
      "type": "string",
      "required": false,
      "default": "CLP"
    },
    {
      "name": "locale",
      "type": "string",
      "required": false,
      "default": "es-CL"
    },
    {
      "name": "timezone",
      "type": "string",
      "required": false,
      "default": "America/Santiago"
    },
    {
      "name": "mainBranch",
      "type": "object",
      "required": true
    },
    {
      "name": "economicActivities",
      "type": "array",
      "required": true
    }
  ],
  "actions": [
    {
      "name": "createCompany",
      "method": "POST",
      "path": "/api/v1/companies",
      "authRequired": true,
      "permissions": ["company.create"]
    },
    {
      "name": "listCompanies",
      "method": "GET",
      "path": "/api/v1/companies",
      "authRequired": true,
      "permissions": ["company.read"]
    },
    {
      "name": "getMyCompanies",
      "method": "GET",
      "path": "/api/v1/companies/me",
      "authRequired": true,
      "permissions": ["company.read"]
    },
    {
      "name": "getCompanyById",
      "method": "GET",
      "path": "/api/v1/companies/:id",
      "authRequired": true,
      "permissions": ["company.read"]
    },
    {
      "name": "updateCompany",
      "method": "PATCH",
      "path": "/api/v1/companies/:id",
      "authRequired": true,
      "permissions": ["company.update"]
    },
    {
      "name": "activateCompany",
      "method": "POST",
      "path": "/api/v1/companies/:id/activate",
      "authRequired": true,
      "permissions": ["company.activate"]
    },
    {
      "name": "suspendCompany",
      "method": "POST",
      "path": "/api/v1/companies/:id/suspend",
      "authRequired": true,
      "permissions": ["company.suspend"]
    },
    {
      "name": "getTenantProvisioning",
      "method": "GET",
      "path": "/api/v1/companies/:id/tenant-provisioning",
      "authRequired": true,
      "permissions": ["company.tenant.read"]
    },
    {
      "name": "retryTenantProvisioning",
      "method": "POST",
      "path": "/api/v1/companies/:id/retry-tenant-provisioning",
      "authRequired": true,
      "permissions": ["company.tenant.retry"]
    },
    {
      "name": "listBranches",
      "method": "GET",
      "path": "/api/v1/companies/:id/branches",
      "authRequired": true,
      "permissions": ["company.branch.read"]
    },
    {
      "name": "createBranch",
      "method": "POST",
      "path": "/api/v1/companies/:id/branches",
      "authRequired": true,
      "permissions": ["company.branch.create"]
    },
    {
      "name": "updateBranch",
      "method": "PATCH",
      "path": "/api/v1/companies/:id/branches/:branchId",
      "authRequired": true,
      "permissions": ["company.branch.update"]
    },
    {
      "name": "setDefaultBranch",
      "method": "POST",
      "path": "/api/v1/companies/:id/branches/:branchId/set-default",
      "authRequired": true,
      "permissions": ["company.branch.update"]
    }
  ],
  "rules": [
    "use company as the canonical term across modules and specs",
    "company master data belongs to the control database",
    "each company maps to exactly one tenant schema",
    "rut must be normalized and validated before persistence",
    "rut_normalized must be unique",
    "tenant_code must be unique and URL-safe",
    "tenant_schema must follow tenant_<tenant_code> and be unique",
    "tenant_schema becomes immutable after provisioning status is ready",
    "company creation requires one main branch",
    "company creation requires at least one economic activity",
    "exactly one economic activity must be primary",
